<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Ignorer les fichiers/dossiers existants
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # NE PAS rediriger les requêtes vers des fichiers PHP existants
    RewriteCond %{REQUEST_FILENAME} !\.php$
    
    # Rediriger /api/* vers /api/index.php (sauf si c'est déjà index.php)
    RewriteCond %{REQUEST_FILENAME} !^.*index\.php$
    RewriteRule ^api/(.*)$ /api/index.php?%{QUERY_STRING} [QSA,L]
    
    # Rediriger racine vers index.html si aucun fichier ne correspond
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/api/
    RewriteRule ^(.*)$ /index.html [QSA,L]
</IfModule>

# DirectoryIndex - Servir index.html par défaut
DirectoryIndex index.html index.php

# Désactiver le listage des répertoires
Options -Indexes

# Gestion du cache
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 hour"
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>
